<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>EventModeling.Testing</RootNamespace>
    <AssemblyName>EventModeling.Testing</AssemblyName>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Assert.fs" />
    <Compile Include="GroupingRunner.fs" />
    <Compile Include="Generators.fs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../EventModeling/EventModeling.fsproj" />
    <PackageReference Include="Expecto" Version="10.*" />
    <PackageReference Include="Hedgehog" Version="0.*" />
    <PackageReference Include="CsCheck" Version="*" />
  </ItemGroup>
</Project>
